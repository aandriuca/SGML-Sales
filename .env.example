# SGML Sales — environment configuration template.
# Copy to `.env` and adjust. `.env` is git-ignored.

# Application
APP_NAME="SGML Sales"
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# Database — defaults to local SQLite; swap for Postgres in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/sgml_sales
DATABASE_URL=sqlite:///./sgml_sales.db

# Company / branding (placeholders — see docs/BRANDING.md)
COMPANY_NAME="[COMPANY NAME — placeholder]"
COMPANY_CURRENCY=USD
